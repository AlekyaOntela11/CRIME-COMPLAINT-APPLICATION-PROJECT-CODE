<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminActivity">
    -<RelativeLayout tools:context="${relativePackage}.${activityClass}"
    android:background="#708090"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:textAppearance="?android:attr/textAppearanceLarge"
        android:textColor="#191970"
        android:textSize="25dp"
        android:text="Welcome Admin!!"
        android:layout_marginTop="29dp"
        android:layout_marginLeft="31dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentLeft="true"
        android:id="@+id/textView1"/>
    <Button
        android:background="#BC8F8F"
        android:layout_height="wrap_content"
        android:layout_width="200dp"
        android:text="view crime reports"
        android:layout_marginTop="47dp"
        android:id="@+id/btviewreport"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/textView1"/>
    <Button
        android:background="#BC8F8F"
        android:layout_height="wrap_content"
        android:layout_width="200dp"
        android:text="Solved Crimes"
        android:layout_marginTop="24dp"
        android:id="@+id/btsolved"
        android:layout_below="@+id/btviewreport"
        android:layout_alignLeft="@+id/btviewreport"/>
    <Button
        android:background="#BC8F8F"
        android:layout_height="wrap_content"
        android:layout_width="200dp"
        android:text="Pending reports"
        android:layout_marginTop="27dp"
        android:id="@+id/btpnding"
        android:layout_below="@+id/btsolved"
        android:layout_alignLeft="@+id/btsolved"/>

    <Button
        android:id="@+id/btfeedback"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_alignLeft="@+id/btpnding"
        android:layout_below="@+id/btpnding"
        android:layout_marginTop="22dp"
        android:background="#BC8F8F"
        android:text="User Details" />
    <Button
        android:background="#BC8F8F"
        android:layout_height="wrap_content"
        android:layout_width="200dp"
        android:text="Home"
        android:layout_marginTop="22dp"
        android:id="@+id/bthome"
        android:layout_below="@+id/btfeedback"
        android:layout_alignLeft="@+id/btfeedback"/>
    </RelativeLayout>
</android.support.constraint.ConstraintLayout>