<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PendingActivity">
    -<RelativeLayout tools:context="${relativePackage}.${activityClass}" android:background="#708090" android:layout_height="match_parent" android:layout_width="match_parent" xmlns:tools="http://schemas.android.com/tools" xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:textSize="25dp" android:textColor="#191970" android:textAppearance="?android:attr/textAppearanceLarge" android:text="Pending Crime Report" android:layout_marginTop="16dp" android:layout_marginLeft="14dp" android:layout_alignParentTop="true" android:layout_alignParentLeft="true" android:id="@+id/textView1"/>
    <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:textSize="25dp" android:textAppearance="?android:attr/textAppearanceLarge" android:text="Place:" android:layout_marginTop="22dp" android:id="@+id/textView3" android:layout_below="@+id/textView2" android:layout_alignLeft="@+id/textView2"/>
    <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:textAppearance="?android:attr/textAppearanceLarge" android:text="Large Text" android:id="@+id/pendingplace" android:layout_alignRight="@+id/scrollView1" android:layout_alignBottom="@+id/textView3" android:layout_alignBaseline="@+id/textView3"/>
    <Button android:background="#BC8F8F" android:layout_height="wrap_content" android:layout_width="80dp" android:text="Finish" android:layout_marginTop="22dp" android:id="@+id/pendingfinish" android:layout_toRightOf="@+id/pendingcrimeviewimg" android:layout_alignTop="@+id/scrollView1"/>
    <ImageView
        android:layout_height="150dp"
        android:layout_width="150dp"
        android:layout_marginTop="36dp"
        android:id="@+id/pendingcrimeviewimg"
        android:layout_below="@+id/textView1"
        android:layout_toRightOf="@+id/textView3"
        android:src="@drawable/ic_launcher"/>
    <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:textSize="25dp" android:textAppearance="?android:attr/textAppearanceLarge" android:text="Date" android:layout_marginTop="28dp" android:id="@+id/textView2" android:layout_below="@+id/pendingcrimeviewimg" android:layout_alignLeft="@+id/textView1"/>
    <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:textAppearance="?android:attr/textAppearanceLarge" android:text="Large Text" android:id="@+id/pendingdate" android:layout_centerHorizontal="true" android:layout_above="@+id/textView3"/>
    -<ScrollView android:layout_height="100dp" android:layout_width="200dp" android:id="@+id/scrollView1" android:layout_below="@+id/textView4" android:layout_alignLeft="@+id/textView4">
    <TextView android:layout_height="match_parent" android:layout_width="match_parent" android:textAppearance="?android:attr/textAppearanceLarge" android:text="Large Text" android:id="@+id/pendingdescription"/>
    </ScrollView>
    <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:textSize="25dp" android:textAppearance="?android:attr/textAppearanceLarge" android:text="Description:" android:id="@+id/textView4" android:layout_below="@+id/textView3" android:layout_alignLeft="@+id/textView3"/>
    <Button android:background="#BC8F8F" android:layout_height="wrap_content" android:layout_width="80dp" android:text="OK" android:id="@+id/pendingok" android:layout_alignTop="@+id/textView3" android:layout_alignParentRight="true"/>
   </RelativeLayout>
</android.support.constraint.ConstraintLayout>